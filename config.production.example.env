# Copy this file to config.production.env and replace every deployment-specific value.
# Do not commit config.production.env because it contains credentials.

# MCP HTTP server. Keep the app on loopback when a reverse proxy exposes HTTPS.
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_PATH=/mcp

# Client authentication. Use long, randomly generated values in production.
MCP_BEARER_TOKENS=
MCP_API_KEYS=test-api-key

# Request validation and proxy trust.
MCP_ALLOWED_HOSTS=192.168.101.171,localhost,127.0.0.1
MCP_ALLOWED_ORIGINS=
MCP_ALLOWED_CLIENT_CIDRS=192.168.101.0/24,127.0.0.1/32
MCP_TRUSTED_PROXY_CIDRS=127.0.0.1/32

# Audit log.
MCP_AUDIT_LOG=./logs/tool_calls.jsonl
